<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Activity.QuanLyActivity">

    <!-- Toolbar tiêu đề -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        app:title="Điện thoại"
        android:layout_marginTop="35dp"
        android:background="#B2B4C1"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"/>

    <!-- Layout chứa các nút chức năng -->
    <LinearLayout
        android:id="@+id/layout_buttons"
        android:layout_width="376dp"
        android:layout_height="122dp"
        android:layout_margin="10dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <!-- Nút Thêm -->
        <LinearLayout
            android:layout_width="98dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            android:background="#B2B4C1"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/img_them"
                android:layout_width="57dp"
                android:layout_height="50dp"
                android:src="@drawable/baseline_add_24"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thêm"
                android:textColor="#D32F2F"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Nút Sửa -->
        <LinearLayout
            android:layout_width="95dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            android:background="#B2B4C1"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/img_sua"
                android:layout_width="58dp"
                android:layout_height="50dp"
                android:src="@drawable/baseline_key_24"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sửa"
                android:textColor="#D32F2F"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Nút Xóa -->
        <LinearLayout
            android:layout_width="95dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:background="#B2B4C1"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/img_xoa"
                android:layout_width="63dp"
                android:layout_height="50dp"
                android:src="@drawable/baseline_remove_24" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xóa"
                android:textColor="#D32F2F"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- Khu vực nội dung chính -->

</androidx.constraintlayout.widget.ConstraintLayout>
